<!-- Read the html_slides_guide instructions before modifying this file. The stage sizing, carousel, controls, and @media print recipe are a strict contract — changing them breaks slide fit and PDF export. -->
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Enterprise Tokenomics</title>
<style>
:root {
  --slide-w: 1280px;
  --slide-h: 720px;
  --stage-w: min(var(--slide-w), 100vw);
  --stage-h: calc(var(--stage-w) * 9 / 16);
  --artifact-background: #f6f7f9;
  --artifact-background-light: #ffffff;
  --artifact-background-mid: #eceef2;
  --artifact-border-light: #e4e7ec;
  --artifact-border-dark: #cbd0d9;
  --artifact-primary-brand: #2f6bff;
  --artifact-primary-soft: rgba(47,107,255,0.08);
  --artifact-text-primary: #0f1319;
  --artifact-text-secondary: #5b616e;
  --artifact-positive: #0f9d64;
  --artifact-positive-soft: rgba(15,157,100,0.10);
  --artifact-warn: #c2660c;
  --artifact-warn-soft: rgba(194,102,12,0.10);
  --artifact-negative: #d9453d;
}
* { box-sizing: border-box; }
body {
  margin: 0; overflow: hidden;
  background-color: var(--artifact-background);
  color: var(--artifact-text-primary);
  font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
  font-size: 16px; font-weight: 400; line-height: 1.5; letter-spacing: -0.005em;
}
h1,h2,h3 { font-weight: 300; line-height: 1.05; letter-spacing: -0.02em; margin: 0; text-wrap: balance; }
.eyebrow { font-family: "SF Mono","IBM Plex Mono","Consolas",monospace; font-size: 1.25cqw; font-weight:600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--artifact-primary-brand); }

/* chassis */
.deck-viewport { position: fixed; inset: 0; display: grid; place-items: center; overflow: hidden; }
.deck { width: var(--stage-w); height: var(--stage-h); overflow: hidden; box-shadow: 0 1px 0 var(--artifact-border-dark), 0 0 0 1px var(--artifact-border-light); }
.deck-track { height:100%; display:flex; transform: translateX(calc(var(--i,0) * -1 * var(--stage-w))); transition: transform 260ms ease; }
.slide { flex: 0 0 var(--stage-w); width: var(--stage-w); height: var(--stage-h); container-type: inline-size; position: relative; display: grid; overflow: clip; contain: layout paint; background: var(--artifact-background); }
.slide > * { min-width: 0; min-height: 0; }
.slide-body { position: absolute; inset: 5cqw; display: grid; grid-template-rows: auto minmax(0,1fr) auto; gap: 2cqw; min-height:0; overflow-wrap: anywhere; }
.slide-head { display:flex; justify-content: space-between; align-items: baseline; gap: 2cqw; }
.slide-main { min-width:0; min-height:0; display:grid; gap: 2cqw; align-content:center; }
.slide-foot { display:flex; justify-content: space-between; align-items:center; font-size: 1.02cqw; color: var(--artifact-text-secondary); border-top: 1px solid var(--artifact-border-light); padding-top: 1cqw; }
.brand-mark { font-family:"SF Mono",monospace; font-size:1.2cqw; letter-spacing:0.08em; color: var(--artifact-text-secondary); }
.brand-mark b { color: var(--artifact-primary-brand); font-weight:700; }

.slide-title { font-size: 4.2cqw; line-height: 1.03; }
.card { background: var(--artifact-background-light); border:1px solid var(--artifact-border-light); border-radius: 10px; padding: 2cqw; }

/* title slide */
.title-kicker { font-family:"SF Mono",monospace; font-size:1.4cqw; letter-spacing:0.2em; text-transform:uppercase; color: var(--artifact-primary-brand); }
.mega { font-size: 6.1cqw; line-height:1.02; font-weight:250; }
.title-sub { font-size: 1.55cqw; color: var(--artifact-text-secondary); max-width: 62ch; line-height:1.45; }
.pill-row { display:flex; gap:1.1cqw; flex-wrap:wrap; }
.pill { font-family:"SF Mono",monospace; font-size:1.1cqw; letter-spacing:0.03em; padding:0.65cqw 1.2cqw; border:1px solid var(--artifact-border-dark); border-radius:999px; color: var(--artifact-text-secondary); }

/* metrics */
.metric { font-weight:250; font-size: 5.2cqw; line-height:1; letter-spacing:-0.03em; font-variant-numeric: tabular-nums; }
.metric.pos { color: var(--artifact-positive); }
.metric.warn { color: var(--artifact-warn); }
.metric.brand { color: var(--artifact-primary-brand); }
.mlabel { font-size:1.2cqw; color: var(--artifact-text-secondary); margin-top:0.6cqw; line-height:1.35; }
.kpi-row { display:grid; grid-template-columns: repeat(3,1fr); gap:1.5cqw; }
.kpi-slim .card { padding:1.2cqw 1.5cqw; }
.kpi-slim .metric { font-size:3.5cqw; }
.kpi-slim .mlabel { font-size:1.0cqw; margin-top:0.4cqw; }

.bodytext { font-size:1.5cqw; color: var(--artifact-text-secondary); line-height:1.5; }
ul.clean { list-style:none; padding:0; margin:0; display:grid; gap:1.05cqw; }
ul.clean li { font-size:1.45cqw; color: var(--artifact-text-secondary); padding-left:2cqw; position:relative; line-height:1.4; }
ul.clean li::before { content:""; position:absolute; left:0; top:0.62cqw; width:0.8cqw; height:0.8cqw; border-radius:2px; background: var(--artifact-primary-brand); }
ul.clean li b { color: var(--artifact-text-primary); font-weight:650; }
.tight li { font-size:1.32cqw !important; line-height:1.34 !important; }

.layout-two-col .slide-main { grid-template-columns: minmax(0,1.05fr) minmax(0,1fr); align-items:center; }

/* flow comparison */
.flow { display:grid; gap:1cqw; }
.flow-row { display:flex; align-items:center; gap:1cqw; padding:1.3cqw 1.5cqw; border-radius:8px; border:1px solid var(--artifact-border-light); background: var(--artifact-background-light); }
.flow-row.bad { border-left:4px solid var(--artifact-warn); }
.flow-row.good { border-left:4px solid var(--artifact-primary-brand); }
.flow-tag { font-family:"SF Mono",monospace; font-size:1.05cqw; letter-spacing:0.06em; text-transform:uppercase; width:13cqw; flex:none; }
.flow-tag.bad { color: var(--artifact-warn); }
.flow-tag.good { color: var(--artifact-primary-brand); }
.chip { font-family:"SF Mono",monospace; font-size:1.02cqw; padding:0.5cqw 0.8cqw; border-radius:5px; white-space:nowrap; }
.chip.bad { border:1px dashed var(--artifact-warn); color: var(--artifact-warn); }
.chip.good { border:1px solid var(--artifact-primary-brand); color: var(--artifact-primary-brand); background: var(--artifact-primary-soft); }
.chip.n { border:1px solid var(--artifact-border-dark); color: var(--artifact-text-secondary); }
.sep { color: var(--artifact-text-secondary); font-size:1.3cqw; }
.flow-note { margin-left:auto; font-size:1.15cqw; font-weight:600; white-space:nowrap; }
.flow-note.bad { color: var(--artifact-warn); }
.flow-note.good { color: var(--artifact-positive); }

/* layer cake */
.cake-wrap { display:grid; grid-template-columns: minmax(0,1fr) 15cqw; gap:1.3cqw; align-items:stretch; }
.cake { display:grid; gap:0.55cqw; }
.layer { display:grid; grid-template-columns: 1fr auto; align-items:center; gap:1.5cqw; padding:0.8cqw 1.4cqw; border-radius:7px; border:1px solid var(--artifact-border-light); background: var(--artifact-background-light); }
.layer .lname { font-size:1.28cqw; font-weight:650; color: var(--artifact-text-primary); }
.layer .lrole { font-size:1.0cqw; color: var(--artifact-text-secondary); line-height:1.28; }
.layer .lmetric { font-family:"SF Mono",monospace; font-size:1.1cqw; color: var(--artifact-positive); text-align:right; white-space:nowrap; }
.layer .lmetric.brand { color: var(--artifact-primary-brand); }
.layer.hot { border-color: var(--artifact-primary-brand); background: var(--artifact-primary-soft); }
.gov-rail { border:1px solid var(--artifact-border-dark); border-radius:7px; background: var(--artifact-background-mid); padding:1.4cqw; display:flex; flex-direction:column; justify-content:center; gap:0.85cqw; }
.gov-rail .gh { font-family:"SF Mono",monospace; font-size:1.05cqw; letter-spacing:0.06em; text-transform:uppercase; color: var(--artifact-primary-brand); font-weight:600; }
.gov-rail .gi { font-size:1.1cqw; color: var(--artifact-text-secondary); line-height:1.28; }
.legend { display:flex; gap:1.6cqw; align-items:center; }
.legend .li { display:flex; align-items:center; gap:0.55cqw; font-size:1.12cqw; color: var(--artifact-text-secondary); white-space:nowrap; }
.legend .sw { width:1.35cqw; height:1.35cqw; border-radius:4px; flex:none; }
.legend .sw.blue { background: var(--artifact-primary-soft); border:1.5px solid var(--artifact-primary-brand); }
.legend .sw.white { background: var(--artifact-background-light); border:1.5px solid var(--artifact-border-dark); }

/* bars */
.bars { display:grid; gap:1.3cqw; align-content:center; }
.col-tag { font-family:"SF Mono",monospace; font-size:1.05cqw; letter-spacing:0.06em; text-transform:uppercase; color: var(--artifact-text-secondary); }
.bar-row { display:grid; grid-template-columns: 11cqw 1fr auto; gap:1.1cqw; align-items:center; }
.bar-lab { font-size:1.25cqw; color: var(--artifact-text-secondary); }
.bar-track { height:2.4cqw; background: var(--artifact-background-mid); border-radius:4px; overflow:hidden; }
.bar-fill { height:100%; border-radius:4px; }
.bar-fill.bad { background: var(--artifact-warn); }
.bar-fill.good { background: var(--artifact-primary-brand); }
.bar-fill.neutral { background: var(--artifact-border-dark); }
.bar-val { font-family:"SF Mono",monospace; font-size:1.2cqw; color: var(--artifact-text-primary); font-variant-numeric: tabular-nums; white-space:nowrap; }

/* reframe table */
.reframe { width:100%; border-collapse:collapse; }
.reframe th { text-align:left; font-family:"SF Mono",monospace; font-size:1.05cqw; letter-spacing:0.06em; text-transform:uppercase; color: var(--artifact-text-secondary); padding:0.7cqw 1cqw; border-bottom:1px solid var(--artifact-border-dark); }
.reframe td { font-size:1.3cqw; padding:0.8cqw 1cqw; border-bottom:1px solid var(--artifact-border-light); color: var(--artifact-text-secondary); vertical-align:top; }
.reframe td.better { color: var(--artifact-text-primary); font-weight:600; }
.reframe td.better::before { content:"→ "; color: var(--artifact-primary-brand); }

/* three-up cards */
.trio { display:grid; grid-template-columns: repeat(3,1fr); gap:1.6cqw; align-content:center; }
.trio .t-h { font-size:1.5cqw; font-weight:650; color: var(--artifact-primary-brand); margin-bottom:0.7cqw; }
.trio .t-b { font-size:1.28cqw; color: var(--artifact-text-secondary); line-height:1.42; }
.trio .t-b b { color: var(--artifact-text-primary); font-weight:650; }
.legend .dot { width:1.1cqw; height:1.1cqw; border-radius:50%; flex:none; }
.tl { position:relative; height:100%; }
.tl-line { position:absolute; left:0; right:0; top:50%; height:2px; background:var(--artifact-border-dark); transform:translateY(-1px); }
.tl-grid { position:relative; height:100%; display:grid; grid-template-columns: repeat(9, minmax(0,1fr)); grid-template-rows: 1fr auto 1fr; column-gap:0.7cqw; align-items:center; }
.tl-dot { grid-row:2; width:1.15cqw; height:1.15cqw; border-radius:50%; background:var(--cat,#0f1319); border:0.35cqw solid var(--artifact-background); justify-self:center; z-index:2; }
.tl-card { border:1px solid var(--artifact-border-light); border-top:3px solid var(--cat,#0f1319); border-radius:6px; padding:0.65cqw 0.7cqw; background:var(--artifact-background-light); }
.tl-card.up { grid-row:1; align-self:end; margin-bottom:1.1cqw; }
.tl-card.down { grid-row:3; align-self:start; margin-top:1.1cqw; }
.tl-card .d { font-family:"SF Mono",monospace; font-size:0.92cqw; color:var(--artifact-primary-brand); font-weight:600; }
.tl-card .t { font-size:1.0cqw; color:var(--artifact-text-primary); font-weight:600; line-height:1.2; margin-top:0.2cqw; }
.tl-card .s { font-size:0.88cqw; color:var(--artifact-text-secondary); line-height:1.18; margin-top:0.25cqw; }

/* controls */
.controls { position: fixed; bottom: 16px; left: 50%; transform: translateX(-50%); display:flex; align-items:center; gap:10px; background: var(--artifact-background-light); border:1px solid var(--artifact-border-light); border-radius:999px; padding:6px 12px; z-index:50; box-shadow: 0 4px 16px rgba(15,19,25,0.08); }
.controls button { background: transparent; border:1px solid var(--artifact-border-dark); color: var(--artifact-text-primary); border-radius:999px; padding:5px 12px; font-size:13px; cursor:pointer; font-family:inherit; }
.controls button:hover { border-color: var(--artifact-primary-brand); color: var(--artifact-primary-brand); }
#counter { font-family:"SF Mono",monospace; font-size:12px; color: var(--artifact-text-secondary); min-width:52px; text-align:center; }

@media print {
  @page { size: 1280px 720px; margin: 0; }
  html, body { width: var(--slide-w); margin:0; overflow: visible; background:#fff; }
  .deck-viewport { position: static; display:block; overflow: visible; }
  .deck { width:auto; height:auto; transform:none; overflow:visible; box-shadow:none; }
  .deck-track { display:block; transform:none; transition:none; }
  *,*::before,*::after { animation:none !important; transition:none !important; }
  .slide { width: var(--slide-w); height: var(--slide-h); aspect-ratio:auto; break-inside:avoid; print-color-adjust:exact; -webkit-print-color-adjust:exact; }
  .slide:not(:last-child) { break-after: page; }
  img, svg { max-width:none; }
  .controls { display:none !important; }
}
</style>
</head>
<body>
<div class="deck-viewport">
  <div class="deck">
    <div class="deck-track">

      <!-- SLIDE 1: TITLE -->
      <section class="slide">
        <div class="slide-body">
          <header class="slide-head">
            <span class="brand-mark"><b>Glean</b> · Southeast Strategic &amp; Enterprise</span>
            <span class="brand-mark">Market POV · 2026</span>
          </header>
          <main class="slide-main" style="gap:1.6cqw;">
            <div class="title-kicker">Enterprise Tokenomics</div>
            <h1 class="mega">The economics of enterprise AI<br>are breaking. Context fixes the math.</h1>
            <p class="title-sub">Frontier token prices and token-hungry agents are compounding cost faster than value. The winning unit is shifting from cost per token to yield per token, and the governed context layer is where that yield is won.</p>
            <div class="pill-row">
              <span class="pill">Cost curve</span>
              <span class="pill">Fan-out vs context layer</span>
              <span class="pill">The Glean stack</span>
              <span class="pill">Open models</span>
              <span class="pill">Sustainability</span>
              <span class="pill">GTM POV</span>
            </div>
          </main>
          <footer class="slide-foot"><span>Confidential</span><span>1 / 10</span></footer>
        </div>
      </section>

      <!-- SLIDE 2: THE MOMENT -->
      <section class="slide layout-two-col">
        <div class="slide-body">
          <header class="slide-head">
            <span class="eyebrow">01 · The moment</span>
            <span class="brand-mark"><b>Glean</b></span>
          </header>
          <main class="slide-main">
            <div>
              <h2 class="slide-title">Token spend is compounding faster than budgets</h2>
              <p class="bodytext" style="margin-top:1.3cqw;">Chat was cheap. Coding, coworking, analysis, and automation are not. As teams move to agentic work, consumption scales non-linearly while frontier prices keep climbing. Cost is the symptom leaders feel first.</p>
              <ul class="clean" style="margin-top:1.5cqw;">
                <li><b>13x</b> growth in average monthly enterprise token spend, Jan 2025 to Jan 2026 (Ramp, 50K+ businesses)</li>
                <li>Teams at <b>Uber and ServiceNow</b> reportedly burned annual AI-coding budgets in the first months of the year</li>
                <li>Frontier list prices keep rising as agents fan out more tool calls and reasoning loops per task</li>
              </ul>
            </div>
            <div class="card" style="display:flex; flex-direction:column; justify-content:center;">
              <div class="col-tag">Avg monthly enterprise token spend (indexed)</div>
              <svg viewBox="0 0 420 230" width="100%" preserveAspectRatio="xMidYMid meet" style="margin-top:6px;">
                <line x1="40" y1="20" x2="40" y2="195" stroke="#cbd0d9"/>
                <line x1="40" y1="195" x2="410" y2="195" stroke="#cbd0d9"/>
                <line x1="40" y1="107" x2="410" y2="107" stroke="#e4e7ec" stroke-dasharray="3 4"/>
                <text x="10" y="199" fill="#5b616e" font-family="monospace" font-size="11">0</text>
                <text x="6" y="111" fill="#5b616e" font-family="monospace" font-size="11">6x</text>
                <text x="2" y="24" fill="#5b616e" font-family="monospace" font-size="11">13x</text>
                <polyline fill="none" stroke="#c2660c" stroke-width="2.5" points="40,193 108,190 176,184 244,172 300,150 348,112 390,26"/>
                <circle cx="390" cy="26" r="5" fill="#c2660c"/>
                <text x="46" y="212" fill="#5b616e" font-family="monospace" font-size="11">Jan '25</text>
                <text x="180" y="212" fill="#5b616e" font-family="monospace" font-size="11">Jul '25</text>
                <text x="352" y="212" fill="#5b616e" font-family="monospace" font-size="11">Jan '26</text>
                <text x="298" y="58" fill="#c2660c" font-family="monospace" font-size="15" font-weight="700">+13x</text>
              </svg>
            </div>
          </main>
          <footer class="slide-foot"><span>Source: Ramp Economics Lab; public reporting on AI coding budgets</span><span>2 / 10</span></footer>
        </div>
      </section>

      <!-- SLIDE 3: FAN-OUT MCP VS CONTEXT LAYER -->
      <section class="slide">
        <div class="slide-body">
          <header class="slide-head">
            <span class="eyebrow">02 · Where the tokens burn</span>
            <span class="brand-mark"><b>Glean</b></span>
          </header>
          <main class="slide-main">
            <h2 class="slide-title" style="max-width:60ch; font-size:2.9cqw;">Fanned-out MCP rebuilds context on every call. A context layer resolves it once.</h2>
            <div class="card" style="display:flex; align-items:center; justify-content:center; padding:1.2cqw 1.8cqw;">
              <svg viewBox="0 0 1060 250" width="100%" preserveAspectRatio="xMidYMid meet" style="font-family:Inter,sans-serif;">
                <defs>
                  <marker id="awarn" markerWidth="7" markerHeight="7" refX="5.5" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6 Z" fill="#c2660c"/></marker>
                  <marker id="abrand" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6 Z" fill="#2f6bff"/></marker>
                </defs>

                <!-- LEFT : fan-out -->
                <text x="24" y="18" fill="#c2660c" font-family="monospace" font-size="14" font-weight="700" letter-spacing="1">FAN-OUT MCP</text>
                <rect x="165" y="32" width="180" height="46" rx="7" fill="#ffffff" stroke="#c2660c" stroke-width="1.5"/>
                <text x="255" y="52" text-anchor="middle" fill="#0f1319" font-size="13" font-weight="600">Agent /</text>
                <text x="255" y="68" text-anchor="middle" fill="#0f1319" font-size="13" font-weight="600">frontier model</text>
                <!-- fan-out arrows -->
                <line x1="255" y1="78" x2="53"  y2="192" stroke="#c2660c" stroke-width="1.5" opacity="0.85" marker-end="url(#awarn)"/>
                <line x1="255" y1="78" x2="151" y2="192" stroke="#c2660c" stroke-width="1.5" opacity="0.85" marker-end="url(#awarn)"/>
                <line x1="255" y1="78" x2="249" y2="192" stroke="#c2660c" stroke-width="1.5" opacity="0.85" marker-end="url(#awarn)"/>
                <line x1="255" y1="78" x2="347" y2="192" stroke="#c2660c" stroke-width="1.5" opacity="0.85" marker-end="url(#awarn)"/>
                <line x1="255" y1="78" x2="445" y2="192" stroke="#c2660c" stroke-width="1.5" opacity="0.85" marker-end="url(#awarn)"/>
                <!-- source boxes -->
                <g font-size="12" fill="#5b616e" text-anchor="middle">
                  <rect x="12"  y="194" width="82" height="34" rx="6" fill="#fff" stroke="#cbd0d9"/><text x="53"  y="215" fill="#0f1319">Jira</text>
                  <rect x="110" y="194" width="82" height="34" rx="6" fill="#fff" stroke="#cbd0d9"/><text x="151" y="215" fill="#0f1319">Slack</text>
                  <rect x="208" y="194" width="82" height="34" rx="6" fill="#fff" stroke="#cbd0d9"/><text x="249" y="215" fill="#0f1319">Drive</text>
                  <rect x="306" y="194" width="82" height="34" rx="6" fill="#fff" stroke="#cbd0d9"/><text x="347" y="215" fill="#0f1319">GitHub</text>
                  <rect x="404" y="194" width="82" height="34" rx="6" fill="#fff" stroke="#cbd0d9"/><text x="445" y="215" fill="#0f1319">CRM</text>
                </g>
                <text x="24" y="247" fill="#c2660c" font-size="12" font-weight="600">N separate calls, re-stitched &amp; re-ranked on every query</text>

                <!-- divider -->
                <line x1="530" y1="6" x2="530" y2="240" stroke="#e4e7ec" stroke-width="1.5" stroke-dasharray="4 5"/>

                <!-- RIGHT : Glean -->
                <text x="560" y="18" fill="#2f6bff" font-family="monospace" font-size="14" font-weight="700" letter-spacing="1">GLEAN CONTEXT LAYER</text>
                <rect x="690" y="32" width="180" height="46" rx="7" fill="#ffffff" stroke="#2f6bff" stroke-width="1.5"/>
                <text x="780" y="52" text-anchor="middle" fill="#0f1319" font-size="13" font-weight="600">Agent /</text>
                <text x="780" y="68" text-anchor="middle" fill="#0f1319" font-size="13" font-weight="600">frontier model</text>
                <line x1="780" y1="78" x2="780" y2="106" stroke="#2f6bff" stroke-width="2.4" marker-end="url(#abrand)"/>
                <text x="792" y="97" fill="#2f6bff" font-size="12" font-weight="600">1 call</text>
